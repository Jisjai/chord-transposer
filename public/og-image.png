<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <!-- Background -->
  <rect width="1200" height="630" fill="#0f0e0d"/>
  <!-- Subtle gradient overlays -->
  <radialGradient id="g1" cx="20%" cy="20%">
    <stop offset="0%" stop-color="#1c1505" stop-opacity="1"/>
    <stop offset="100%" stop-color="#0f0e0d" stop-opacity="0"/>
  </radialGradient>
  <radialGradient id="g2" cx="80%" cy="80%">
    <stop offset="0%" stop-color="#050f05" stop-opacity="1"/>
    <stop offset="100%" stop-color="#0f0e0d" stop-opacity="0"/>
  </radialGradient>
  <rect width="1200" height="630" fill="url(#g1)"/>
  <rect width="1200" height="630" fill="url(#g2)"/>

  <!-- Gold gradient for logo and accents -->
  <defs>
    <linearGradient id="gold" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#e8c96a"/>
      <stop offset="100%" stop-color="#a07820"/>
    </linearGradient>
  </defs>

  <!-- Logo flat symbol -->
  <rect x="80" y="160" width="22" height="180" rx="11" fill="url(#gold)"/>
  <ellipse cx="136" cy="316" rx="58" ry="44" fill="url(#gold)"/>
  <ellipse cx="136" cy="312" rx="34" ry="26" fill="#0f0e0d"/>

  <!-- Title -->
  <text x="220" y="260" font-family="Georgia, serif" font-size="72" fill="#e8e0d0" font-weight="normal" letter-spacing="2">Chord Transposer</text>

  <!-- Subtitle -->
  <text x="220" y="320" font-family="'Helvetica Neue', sans-serif" font-size="32" fill="#6b6456" letter-spacing="3">TRANSPOSE ANY SONG INSTANTLY</text>

  <!-- Feature pills -->
  <rect x="220" y="370" width="220" height="44" rx="22" fill="#1a1916" stroke="#2a2820" stroke-width="1"/>
  <text x="330" y="398" font-family="sans-serif" font-size="18" fill="#c8a84b" text-anchor="middle">AI Vision</text>

  <rect x="456" y="370" width="260" height="44" rx="22" fill="#1a1916" stroke="#2a2820" stroke-width="1"/>
  <text x="586" y="398" font-family="sans-serif" font-size="18" fill="#c8a84b" text-anchor="middle">Guitar + Piano Diagrams</text>

  <rect x="732" y="370" width="200" height="44" rx="22" fill="#1a1916" stroke="#2a2820" stroke-width="1"/>
  <text x="832" y="398" font-family="sans-serif" font-size="18" fill="#c8a84b" text-anchor="middle">Free to Use</text>

  <!-- URL -->
  <text x="220" y="500" font-family="sans-serif" font-size="24" fill="#3a3428" letter-spacing="2">chord-transposer-gamma.vercel.app</text>

  <!-- Decorative staff lines on the right -->
  <line x1="980" y1="180" x2="1140" y2="180" stroke="#1a1916" stroke-width="2"/>
  <line x1="980" y1="210" x2="1140" y2="210" stroke="#1a1916" stroke-width="2"/>
  <line x1="980" y1="240" x2="1140" y2="240" stroke="#1a1916" stroke-width="2"/>
  <line x1="980" y1="270" x2="1140" y2="270" stroke="#1a1916" stroke-width="2"/>
  <line x1="980" y1="300" x2="1140" y2="300" stroke="#1a1916" stroke-width="2"/>
  <!-- Chord names on staff -->
  <text x="990" y="205" font-family="'Courier New', monospace" font-size="20" fill="#c8a84b">Am</text>
  <text x="1040" y="235" font-family="'Courier New', monospace" font-size="20" fill="#c8a84b">G</text>
  <text x="1075" y="265" font-family="'Courier New', monospace" font-size="20" fill="#c8a84b">F</text>
  <text x="990" y="295" font-family="'Courier New', monospace" font-size="20" fill="#c8a84b">C</text>
  <!-- Arrow -->
  <text x="990" y="380" font-family="sans-serif" font-size="28" fill="#4a4438">↓</text>
  <!-- Transposed -->
  <text x="990" y="430" font-family="'Courier New', monospace" font-size="20" fill="#e8e0d0">Bm</text>
  <text x="1040" y="430" font-family="'Courier New', monospace" font-size="20" fill="#e8e0d0">A</text>
  <text x="1075" y="430" font-family="'Courier New', monospace" font-size="20" fill="#e8e0d0">G</text>
  <text x="990" y="460" font-family="'Courier New', monospace" font-size="20" fill="#e8e0d0">D</text>
</svg>
